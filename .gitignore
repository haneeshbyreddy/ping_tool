# Local state lives under data/ (regenerate: see README). Whole dir is git-ignored
# except a .gitkeep so the directory exists on a fresh clone.
/data/*
!/data/.gitkeep
*.db
*.db-wal
*.db-shm

# Python
__pycache__/
*.pyc
.venv/
venv/

# Local env overrides
.env

# Generated by deploy/install.ps1 (machine-specific launcher paths)
/deploy/wisp-*-run.cmd

# Stamped by CI at build time from `git describe` (Phase 10 Part D); absent in dev checkouts.
/src/wisp/_buildinfo.py
# Edge update directive handoff (shipper -> supervisor); transient runtime state.
update_request.json
# PyInstaller build output.
/build/
/dist/
