# Local state lives under data/ (regenerate: see README). Whole dir is git-ignored
# except a .gitkeep so the directory exists on a fresh clone.
/data/*
!/data/.gitkeep
*.db
*.db-wal
*.db-shm

# Python
__pycache__/
*.pyc
.venv/
venv/

# Local env overrides
.env

# Generated by deploy/install.ps1 (machine-specific launcher paths)
/deploy/wisp-*-run.cmd
